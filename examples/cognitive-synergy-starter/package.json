  "description": "Starter template for Cognitive Synergy Engine (V8+libuv under cognitive control)",
  "main": "lib/cognitive_api.js",
  "scripts": {
    "build": "mkdir -p build && cd build && cmake .. && make",
    "clean": "rm -rf build",
    "test": "node examples/basic.js",
